<div class="iframe-module">
  <h2><%= data[:title] || "Embedded Content" %></h2>
  <div class="iframe-container">
    <% if data[:url].present? && data[:url] != "about:blank" %>
      <iframe
        src="<%= data[:url] %>"
        frameborder="0"
        allowfullscreen
        loading="lazy"
        sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
        title="<%= data[:title] || 'Embedded Content' %>"
      ></iframe>
    <% else %>
      <div class="iframe-placeholder">
        <p>No URL provided. Pass <code>?iframe_url=https://example.com</code> in the query string.</p>
      </div>
    <% end %>
  </div>
</div>

<style>
  .iframe-module h2 {
    margin-top: 0;
    text-align: center;
    font-size: 1.8em;
    margin-bottom: 15px;
  }

  .iframe-container {
    width: 100%;
    height: 0;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    position: relative;
    border-radius: 8px;
    overflow: hidden;
  }

  .iframe-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 8px;
  }

  .iframe-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 1.1em;
    text-align: center;
    padding: 20px;
  }

  .iframe-placeholder code {
    background: rgba(255, 255, 255, 0.15);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }
</style>

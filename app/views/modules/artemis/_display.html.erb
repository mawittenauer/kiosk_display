  }

  .status-badge {
    background: rgba(34, 197, 94, 0.2);
    color: #22c55e;
    padding: 4px 14px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.95em;
  }

  .vehicle-badge {
    background: rgba(59, 130, 246, 0.2);
    color: #60a5fa;
    padding: 4px 14px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.95em;
  }

  .artemis-countdown {
    text-align: center;
    margin: 20px 0;
  }

  .countdown-label {
    font-size: 1em;
    opacity: 0.7;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .countdown-digits {
    font-size: 2.6em;
    font-weight: bold;
    font-variant-numeric: tabular-nums;
    letter-spacing: 2px;
    color: #f59e0b;
  }

  .artemis-description {
    text-align: center;
    opacity: 0.85;
    font-size: 0.95em;
    line-height: 1.5;
    margin: 0 10px 20px;
  }

  .artemis-section h3 {
    text-align: center;
    font-size: 1.2em;
    margin-bottom: 12px;
    font-weight: 600;
    letter-spacing: 1px;
  }

  .crew-grid {

<div class="artemis-module">
  <h2>🚀 Artemis II — Lunar Flyby Mission</h2>

  <div class="artemis-status-bar">
    <span class="status-badge"><%= data[:status] %></span>
    <span class="vehicle-badge"><%= data[:vehicle] %></span>
  </div>

  <div class="artemis-countdown" id="artemis-countdown"
       data-launch="<%= data[:launch_date] %>">
    <div class="countdown-label">Countdown to Launch</div>
    <div class="countdown-digits" id="artemis-countdown-digits">--d --h --m --s</div>
  </div>

  <p class="artemis-description"><%= data[:description] %></p>

  <div class="artemis-section">
    <h3>Crew</h3>
    <div class="crew-grid">
      <% data[:crew].each do |member| %>
        <div class="crew-card">
          <div class="crew-name"><%= member[:name] %></div>
          <div class="crew-role"><%= member[:role] %></div>
          <div class="crew-agency"><%= member[:agency] %> · <%= member[:nationality] %></div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="artemis-section">
    <h3>Mission Timeline</h3>
    <div class="milestones">
      <% data[:milestones].each do |ms| %>
        <div class="milestone <%= ms[:completed] ? 'completed' : 'pending' %>">
          <span class="ms-indicator"><%= ms[:completed] ? '✅' : '⬜' %></span>
          <span class="ms-name"><%= ms[:name] %></span>
          <span class="ms-date"><%= Date.parse(ms[:date].to_s).strftime('%b %d, %Y') rescue ms[:date] %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="artemis-meta">
    <span>📍 <%= data[:pad] %></span>
    <span class="artemis-updated">Updated: <%= data[:last_updated] %></span>
  </div>
</div>

<style>

    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 24px;
  }

  .crew-card {
    background: rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    padding: 12px;
    text-align: center;
  }

  .crew-name {
    font-weight: 700;
    font-size: 1.05em;
    margin-bottom: 2px;
  }

  .crew-role {
    font-size: 0.9em;

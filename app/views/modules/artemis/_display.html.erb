<div class="artemis-module" id="artemis-module"
     data-launch="<%= data[:launch_time] %>"
     data-progress="<%= data[:progress_pct] %>">

  <div class="art-header">
    <span class="art-title">🚀 Artemis II</span>
    <span class="art-met" id="artemis-met">MET --:--:--</span>
  </div>

  <div class="art-phase">
    <span class="art-phase-icon"><%= data[:status_icon] %></span>
    <span class="art-phase-label" id="artemis-phase"><%= data[:status] %></span>
  </div>

  <!-- Journey progress bar -->
  <div class="art-journey">
    <div class="art-progress-track">
      <div class="art-progress-fill" id="artemis-progress" style="width: <%= data[:progress_pct] %>%"></div>
      <div class="art-progress-marker" id="artemis-marker" style="left: <%= data[:progress_pct] %>%">▲</div>
    </div>
    <div class="art-phase-labels">
      <% data[:phases]&.each do |p| %>
        <span class="art-plabel <%= 'active' if p[:active] %>"><%= p[:icon] %></span>
      <% end %>
    </div>
  </div>

  <% if data[:next_milestone] %>
    <div class="art-next">
      Next: <strong><%= data[:next_milestone][:name] %></strong>
    </div>
  <% end %>

  <!-- Milestones compact -->
  <div class="art-milestones">
    <% data[:milestones]&.each do |ms| %>
      <div class="art-ms <%= ms[:completed] ? 'done' : 'pending' %>">
        <span class="art-ms-dot"><%= ms[:completed] ? '●' : '○' %></span>
        <span class="art-ms-name"><%= ms[:name] %></span>
      </div>
    <% end %>
  </div>

  <!-- Crew single row -->
  <div class="art-crew">
    <% data[:crew]&.each do |m| %>
      <span class="art-crew-member"><%= m[:name].split.last %> <small>(<%= m[:role] %>)</small></span>
    <% end %>
  </div>

  <div class="art-footer">
    <span><%= data[:vehicle] %></span>
    <span class="artemis-updated">Updated: <%= data[:last_updated] %></span>
  </div>
</div>

<style>
  .artemis-module {
    font-size: 0.9em;
  }

  .art-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }

  .art-title {
    font-size: 1.3em;
    font-weight: 700;
  }

  .art-met {
    font-family: monospace;
    font-size: 1.1em;
    font-weight: 600;
    color: #f59e0b;
    font-variant-numeric: tabular-nums;
  }

  .art-phase {
    text-align: center;
    margin: 8px 0 10px;
    font-size: 1.15em;
    font-weight: 600;
  }

  .art-phase-icon {
    margin-right: 6px;
    font-size: 1.1em;
  }

  /* Journey progress */
  .art-journey {
    margin: 6px 0 10px;
  }

  .art-progress-track {
    position: relative;
    height: 6px;
    background: rgba(255,255,255,0.1);
    border-radius: 3px;
    overflow: visible;
  }

  .art-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #22c55e, #3b82f6, #f59e0b);
    border-radius: 3px;
    transition: width 1s ease;
  }

  .art-progress-marker {
    position: absolute;
    top: 8px;
    transform: translateX(-50%);
    font-size: 0.7em;
    color: #f59e0b;
    transition: left 1s ease;
  }

  .art-phase-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 8px;
    font-size: 0.95em;
  }

  .art-plabel {
    opacity: 0.35;
    transition: opacity 0.3s;
  }

  .art-plabel.active {
    opacity: 1;
    filter: drop-shadow(0 0 4px rgba(245,158,11,0.6));
  }

  .art-next {
    text-align: center;
    font-size: 0.85em;
    opacity: 0.8;
    margin-bottom: 8px;
    color: #60a5fa;
  }

  /* Milestones compact */
  .art-milestones {
    display: flex;
    flex-wrap: wrap;
    gap: 2px 12px;
    margin-bottom: 8px;
  }

  .art-ms {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8em;
    white-space: nowrap;
  }

  .art-ms.done {
    opacity: 0.5;
  }

  .art-ms.pending {
    color: #f59e0b;
  }

  .art-ms-dot {
    font-size: 0.7em;
  }

  /* Crew compact row */
  .art-crew {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 10px;
    font-size: 0.78em;
    opacity: 0.7;
    margin-bottom: 6px;
  }

  .art-crew-member small {
    opacity: 0.6;
  }

  .art-footer {
    display: flex;
    justify-content: space-between;
    font-size: 0.75em;
    opacity: 0.4;
  }
</style>
